{
  "permissions": {
    "allow": [
      "Bash(cd:*)",
      "Bash(find:*)",
      "Bash(cp:*)"
    ],
    "permissionMode": "default"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/notify.sh \"Claude Code\" \"任务已完成，请查看结果\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/notify.sh \"Claude Code\" \"需要你确认操作\""
          }
        ]
      }
    ]
  }
}
